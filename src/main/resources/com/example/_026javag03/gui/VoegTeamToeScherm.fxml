<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            styleClass="content-pane">

    <center>
        <VBox spacing="25"
              alignment="TOP_CENTER"
              styleClass="card"
              maxWidth="650">

            <padding>
                <Insets top="40" right="60" bottom="40" left="60"/>
            </padding>

            <!-- Titel -->
            <Label text="Nieuw Team Aanmaken"
                   styleClass="form-title"/>

            <!-- Info melding -->
            <Label fx:id="lblInfo"
                   wrapText="true"
                   styleClass="form-info"/>

            <GridPane hgap="20" vgap="20">

                <columnConstraints>
                    <ColumnConstraints percentWidth="35"/>
                    <ColumnConstraints percentWidth="65"/>
                </columnConstraints>

                <!-- Site -->
                <Label text="Site"
                       GridPane.rowIndex="0"
                       GridPane.columnIndex="0"/>

                <ComboBox fx:id="siteBox"
                          promptText="Selecteer een site"
                          maxWidth="Infinity"
                          GridPane.rowIndex="0"
                          GridPane.columnIndex="1"/>

                <!-- Verantwoordelijke -->
                <Label text="Verantwoordelijke"
                       GridPane.rowIndex="1"
                       GridPane.columnIndex="0"/>

                <ComboBox fx:id="verantwoordelijkeBox"
                          promptText="Selecteer een verantwoordelijke"
                          maxWidth="Infinity"
                          GridPane.rowIndex="1"
                          GridPane.columnIndex="1"/>

            </GridPane>

            <Separator/>

            <!-- Buttons -->
            <HBox spacing="15"
                  alignment="CENTER_RIGHT">

                <Button text="← Terug"
                        styleClass="secondary-button"
                        onAction="#handleTerug"/>

                <Button fx:id="btnToevoegen"
                        text="Team Aanmaken"
                        styleClass="primary-button"
                        onAction="#handleToevoegen"/>
            </HBox>

        </VBox>
    </center>

</BorderPane>