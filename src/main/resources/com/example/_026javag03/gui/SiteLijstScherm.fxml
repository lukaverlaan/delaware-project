<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            styleClass="content-pane">

    <center>

        <VBox spacing="25" alignment="TOP_LEFT" styleClass="card">

            <padding>
                <Insets top="40" right="60" bottom="40" left="60"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="20">

                <Label text="Sites" styleClass="title"/>

                <Pane HBox.hgrow="ALWAYS"/>

            </HBox>

            <HBox spacing="20" alignment="CENTER_LEFT">

                <TextField fx:id="txtFilter"
                           promptText="Zoek site..."
                           styleClass="search-field"/>

                <CheckBox fx:id="actiefCheckBox"
                          text="Actief"
                          selected="true"/>

                <CheckBox fx:id="inactiefCheckBox"
                          text="Inactief"
                          selected="true"/>

                <ComboBox fx:id="productieStatusFilterComboBox"
                          promptText="Productiestatus"
                          prefWidth="160"/>

                <Pane HBox.hgrow="ALWAYS"/>

                <Button fx:id="btnNieuweSite"
                        text="+ Nieuwe site"
                        styleClass="primary-button"/>

            </HBox>

            <TableView fx:id="tblvSites"
                       VBox.vgrow="ALWAYS">

                <columns>

                    <TableColumn fx:id="tblcNaam"
                                 text="Naam"/>

                    <TableColumn fx:id="tblcLocatie"
                                 text="Locatie"/>

                    <TableColumn fx:id="tblcCapaciteit"
                                 text="Capaciteit"/>

                    <TableColumn fx:id="tblcOperationeleStatus"
                                 text="Operationele status"/>

                    <TableColumn fx:id="tblcProductieStatus"
                                 text="Productie status"/>

                </columns>

                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>

            </TableView>

        </VBox>

    </center>

</BorderPane>