<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            styleClass="content-pane">

    <center>

        <VBox spacing="25" alignment="TOP_LEFT" styleClass="card">

            <padding>
                <Insets top="40" right="60" bottom="40" left="60"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="20">

                <Label text="Teams" styleClass="title"/>

                <Pane HBox.hgrow="ALWAYS"/>

            </HBox>

            <HBox spacing="20" alignment="CENTER_LEFT">

                <TextField fx:id="txtFilter"
                           promptText="Zoek team..."
                           styleClass="search-field"/>

                <Pane HBox.hgrow="ALWAYS"/>

                <Button fx:id="btnNieuwTeam"
                        text="+ Nieuw team"
                        styleClass="primary-button"/>

            </HBox>

            <TableView fx:id="tblvTeams"
                       VBox.vgrow="ALWAYS">

                <columns>

                    <TableColumn fx:id="tblcCode"
                                 text="Code"/>

                    <TableColumn fx:id="tblcSite"
                                 text="Site"/>

                    <TableColumn fx:id="tblcVerantwoordelijke"
                                 text="Verantwoordelijke"/>

                    <TableColumn fx:id="tblcAantalMedewerkers"
                                 text="Aantal Medewerkers"/>

                </columns>

                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>

            </TableView>

        </VBox>

    </center>

</BorderPane>