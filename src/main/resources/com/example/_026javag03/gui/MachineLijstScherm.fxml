<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="content-pane" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1">
    <center>
        <VBox alignment="TOP_LEFT" prefHeight="573.0" prefWidth="633.0" spacing="25" styleClass="card" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="40" left="60" right="60" top="40" />
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="20">
                <Label styleClass="title" text="Machines" />
                <Pane HBox.hgrow="ALWAYS" />
            </HBox>

            <!-- Filters -->
            <HBox alignment="CENTER_LEFT" spacing="20">

                <!-- Zoek -->
                <TextField fx:id="txtFilter" promptText="Zoek machine..." styleClass="search-field" />

                <!-- Status filter -->
                <VBox spacing="5">
                    <Label text="Status" />
                    <ComboBox fx:id="statusFilterComboBox"
                              prefWidth="160"
                              promptText="Alle statussen" />
                </VBox>

                <!-- Site filter -->
                <VBox spacing="5">
                    <Label text="Site" />
                    <ComboBox fx:id="siteFilterComboBox"
                              prefWidth="160"
                              promptText="Alle sites" />
                </VBox>

                <Pane HBox.hgrow="ALWAYS" />

                <!-- Nieuwe machine -->
                <Button fx:id="btnNieuweMachine"
                        styleClass="primary-button"
                        text="+ Nieuwe Machine" />

            </HBox>

            <!-- Tabel -->
            <TableView fx:id="tblvMachines" VBox.vgrow="ALWAYS">

                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>

                <columns>
                    <TableColumn fx:id="tblcStatus" text="Status" />
                    <TableColumn fx:id="tblcProductInfo" text="Product info" />
                    <TableColumn fx:id="tblcSite" text="Site" />
                    <TableColumn fx:id="tblcOnderhoud" text="Onderhoud" />
                    <TableColumn fx:id="tblcUptime" text="Uptime" />
                </columns>

            </TableView>

        </VBox>
    </center>
</BorderPane>