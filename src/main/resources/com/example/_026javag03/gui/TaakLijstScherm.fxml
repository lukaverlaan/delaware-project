<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="content-pane" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1">
   <center>
        <VBox alignment="TOP_LEFT" prefHeight="573.0" prefWidth="633.0" spacing="25" styleClass="card" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="40" left="60" right="60" top="40" />
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="20">
                <Label styleClass="title" text="Machines" />
                <Pane HBox.hgrow="ALWAYS" />
            </HBox>

            <!-- Zoekveld in aparte HBox zodat het niet uitrekt -->
            <HBox alignment="CENTER_LEFT" spacing="20">

                <TextField fx:id="txtFilter" promptText="Zoek machine..." styleClass="search-field" />

                <Pane HBox.hgrow="ALWAYS">
               <children>
                  <ComboBox fx:id="statusFilterComboBox" prefHeight="25.0" prefWidth="207.0" promptText="Filter op status" />
               </children></Pane>

                <Button fx:id="btnNieuweMachine" styleClass="primary-button" text="+ Nieuwe Machine" />

            </HBox>

            <TableView fx:id="tblvMachines" VBox.vgrow="ALWAYS">

                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            <columns>
               <TableColumn fx:id="tblcStatus" prefWidth="75.0" text="Status" />
               <TableColumn fx:id="tblcProductInfo" prefWidth="75.0" text="Product info" />
               <TableColumn fx:id="tblcSite" prefWidth="75.0" text="Site" />
               <TableColumn fx:id="tblcOnderhoud" prefWidth="75.0" text="Onderhoud" />
               <TableColumn fx:id="tblcUptime" prefWidth="75.0" text="Uptime" />
            </columns>

            </TableView>

        </VBox>
   </center>

</BorderPane>
