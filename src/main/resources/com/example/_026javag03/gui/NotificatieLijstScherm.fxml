<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            styleClass="content-pane">

    <center>

        <VBox spacing="25" alignment="TOP_LEFT" styleClass="card">

            <padding>
                <Insets top="40" right="60" bottom="40" left="60"/>
            </padding>

            <!-- HEADER -->
            <HBox alignment="CENTER_LEFT" spacing="20">

                <Label text="Notificaties" styleClass="title"/>

            </HBox>

            <!-- FILTER -->
            <HBox spacing="20" alignment="CENTER_LEFT">

                <TextField fx:id="txtFilter"
                           promptText="Zoek notificatie..."
                           styleClass="search-field"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnNieuweNotificatie"
                        text="+ Nieuwe notificatie"
                        styleClass="primary-button"/>
            </HBox>

            <!-- TABLE -->
            <TableView fx:id="tblvNotificaties"
                       VBox.vgrow="ALWAYS">

                <columns>

                    <TableColumn fx:id="tblcCode" text="Code"/>
                    <TableColumn fx:id="tblcDatum" text="Datum"/>
                    <TableColumn fx:id="tblcType" text="Type"/>
                    <TableColumn fx:id="tblcInhoud" text="Inhoud"/>
                    <TableColumn fx:id="tblcStatus" text="Status"/>

                </columns>

                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>

            </TableView>

        </VBox>

    </center>

</BorderPane>